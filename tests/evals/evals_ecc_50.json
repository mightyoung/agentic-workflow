  "evaluation_metrics": {
    "trigger_accuracy": {
      "formula": "正确触发次数 / 总触发次数",
      "target": ">95%"
    },
    "phase_effectiveness": {
      "formula": "(优化后指标 - 基准指标) / 基准指标",
      "target": "显著正向提升"
    },
    "ecc_fallback_rate": {
      "formula": "降级次数 / ECC调用总次数",
      "target": "<20% (当ECC不存在时)"
    },
    "quality_improvement": {
      "formula": "with_skill_score / baseline_score",
      "target": ">1.3 (30%提升)"
    },
    "execution_speed": {
      "formula": "baseline_time / with_skill_time",
      "target": ">0.8 (允许合理增加以换取质量)"
    },
    "context_efficiency": {
      "公式": "有用信息token / 总token",
      "target": ">60%"
    }
  },

  "test_methodology": {
    "approach": "A/B对比测试",
    "baseline": "不使用agentic-workflow的直接执行",
    "treatment": "使用agentic-workflow的完整流程",
    "measurement": [
      "token消耗统计",
      "执行时间测量",
      "输出质量评分",
      "上下文利用率"
    ]
  }
}
