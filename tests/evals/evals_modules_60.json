  "evaluation_metrics": {
    "trigger_accuracy": {
      "正确触发了expected_module / 总测试数": "目标>95%"
    },
    "checks_pass_rate": {
      "通过的checks数 / 总checks数": "目标>85%"
    },
    "output_quality": {
      "人工或LLM评估": "目标>4/5分"
    },
    "module_switching": {
      "正确切换 / 触发切换次数": "目标>90%"
    }
  },

  "test_methodology": {
    "每个module": [
      "1. 触发检测测试 - 验证能否被正确触发",
      "2. 功能验证测试 - 验证核心功能是否工作",
      "3. 输出质量测试 - 验证输出质量",
      "4. 边界条件测试 - 验证边界情况处理",
      "5. 多阶段触发测试 - 验证与其他module的交互"
    ],
    "评估方式": [
      "1. 自动化检测 - 检查是否调用预期函数/创建预期文件",
      "2. 输出验证 - 检查输出是否符合预期格式",
      "3. 人工评审 - 对关键输出进行人工评分"
    ]
  }
}
